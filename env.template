# --- Network & System ---
PUID=1000
PGID=1000
TZ=America/Los_Angeles
SERVER_IP=

# --- VPN (ProtonVPN) ---
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
# Replace with your actual Wireguard private key
WIREGUARD_PRIVATE_KEY=

# --- Media Stack API Keys ---
# You will populate these AFTER the first run
SONARR_API_KEY=your_sonarr_key_here
RADARR_API_KEY=your_radarr_key_here
PROWLARR_API_KEY=your_prowlarr_key_here

# --- Paths ---
# This makes it easy to change if you move your HDD later
STORAGE_PATH=/mnt/storage/data